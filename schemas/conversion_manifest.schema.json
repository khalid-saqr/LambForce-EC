{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/khalid-saqr/LambForce-EC/schemas/conversion_manifest.schema.json",
  "title": "LambForce-EC archive conversion manifest",
  "type": "object",
  "required": [
    "artery_id",
    "artery_name",
    "radius_m",
    "omega0_rad_s",
    "source_identifier",
    "source_version",
    "coordinate_convention",
    "hydrodynamic_contract"
  ],
  "properties": {
    "artery_id": {
      "enum": [
        "aortic_root",
        "thoracic_aorta",
        "femoral",
        "carotid",
        "iliac",
        "brachial"
      ]
    },
    "artery_name": {
      "type": "string",
      "minLength": 1
    },
    "radius_m": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "omega0_rad_s": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "source_identifier": {
      "type": "string",
      "minLength": 1
    },
    "source_version": {
      "type": "string",
      "minLength": 1
    },
    "coordinate_convention": {
      "const": "outward_normal_positive"
    },
    "expected_archive_sha256": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      ]
    },
    "expected_source_member_sha256": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      ]
    },
    "hydrodynamic_contract": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
