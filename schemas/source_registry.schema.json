{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/khalid-saqr/LambForce-EC/schemas/source_registry.schema.json",
  "title": "LambForce-EC immutable source registry",
  "type": "object",
  "required": [
    "registry_version",
    "sources"
  ],
  "properties": {
    "registry_version": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_identifier",
          "source_version",
          "artery_ids",
          "archive_status",
          "archive_sha256",
          "source_member_sha256_by_artery",
          "conversion_manifest_sha256_by_artery",
          "converter_commit_sha",
          "role",
          "claim_bearing"
        ],
        "properties": {
          "source_identifier": {
            "type": "string",
            "minLength": 1
          },
          "source_version": {
            "type": "string",
            "minLength": 1
          },
          "artery_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "archive_status": {
            "enum": [
              "awaiting_archive",
              "verified",
              "synthetic_non_claim_bearing"
            ]
          },
          "archive_sha256": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              }
            ]
          },
          "source_member_sha256_by_artery": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          },
          "conversion_manifest_sha256_by_artery": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          },
          "converter_commit_sha": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              }
            ]
          },
          "role": {
            "enum": [
              "immutable_hydrodynamic_ground_truth",
              "software_validation_only"
            ]
          },
          "claim_bearing": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
