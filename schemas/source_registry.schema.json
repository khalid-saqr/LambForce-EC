{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LambForce-EC published-source registry",
  "type": "object",
  "required": ["registry_version", "sources"],
  "properties": {
    "registry_version": {"type": "string"},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_identifier", "source_version", "artery_ids", "source_status",
          "repository_commit_sha", "published_notebook_path", "published_notebook_blob_sha",
          "published_input_registry_sha256", "reproduction_commit_sha",
          "record_payload_sha256_by_mode_and_artery", "qualification_status",
          "role", "claim_bearing"
        ],
        "properties": {
          "source_status": {
            "enum": ["frozen_published_source", "verified_reproduction", "synthetic_non_claim_bearing"]
          },
          "qualification_status": {
            "enum": ["awaiting_six_artery_reproduction", "awaiting_historical_oracle", "verified", "not_applicable"]
          },
          "repository_commit_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
          "published_notebook_blob_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
          "published_input_registry_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "reproduction_commit_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
          "role": {"enum": ["published_hydrodynamic_ground_truth", "software_validation_only"]},
          "claim_bearing": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
